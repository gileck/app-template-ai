# Safety net for Vercel builds that install via `npm` (e.g. a child project that
# doesn't commit yarn.lock). npm's strict peer resolution otherwise fails on
# openai@4.x (peer zod 3) vs this stack's zod 4 — yarn tolerates it locally; this
# makes npm tolerant too so the install never ERESOLVEs. No-op under yarn.
legacy-peer-deps=true
